APP_TITLE=Mail Archive Operator Console v5
APP_HOST=127.0.0.1
APP_PORT=8010
APP_BASE_URL=http://127.0.0.1:8010

DB_PATH=data/archive.db
STORAGE_ROOT=storage
INGEST_INTERVAL_MINUTES=30

POP3_HOST=
POP3_USER=
POP3_PASS=
POP3_USE_SSL=true
POP3_PORT=995
POP3_DELETE_AFTER_FETCH=false
POP3_MAX_MESSAGES_PER_RUN=30

LLM_ENABLED=true
LLM_API_BASE=
LLM_MODEL=openai/gpt-oss-120b
LLM_CREDENTIAL_KEY=
LLM_USER_ID=
LLM_USER_TYPE=AD_ID
LLM_SEND_SYSTEM_NAME=GOC_MAIL_RAG_PIPELINE
LLM_TIMEOUT_SECONDS=60
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1200

SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USER=
SMTP_PASS=
REPORT_FROM_EMAIL=
REPORT_TO_EMAILS=
WEEKLY_REPORT_AUTO_SEND=false
WEEKLY_REPORT_SEND_WEEKDAY=1
WEEKLY_REPORT_SEND_HOUR=9
